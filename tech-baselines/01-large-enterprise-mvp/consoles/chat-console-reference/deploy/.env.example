# Console environment

# Provider (Phase 1: claude-cli only; openai planned for Phase 4)
CHAT_CONSOLE_PROVIDER=claude-cli

# Path to chat-console checkout — enables harness sidebar + actions.
# If unset, console runs as a plain chat app.
CHAT_CONSOLE_WORKSPACE=/path/to/chat-console

# Server bind
CONSOLE_HOST=0.0.0.0
CONSOLE_PORT=8080

# Encrypted session cookies. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONSOLE_SECRET_KEY=

# GitHub OAuth (https://github.com/settings/developers).
# Authorization callback URL: http(s)://<host>:<port>/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
CONSOLE_AUTH_ALLOWLIST=[ENTERPRISE: maintainer id]

# Optional: override paths (default to console/-relative)
CHAT_CONSOLE_MEMORY=
CHAT_CONSOLE_HISTORY=./history
CHAT_CONSOLE_DOWNLOADS=./downloads
CHAT_CONSOLE_TURNS=./turns
