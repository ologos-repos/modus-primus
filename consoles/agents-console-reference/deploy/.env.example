# Agents Console — environment configuration
#
# Copy this file to .env and replace [ENTERPRISE:] markers with adopter-side
# values. The console reads this at start; the systemd unit's EnvironmentFile
# directive loads it.

# === Workspace anchoring ===
# Where the agents console runs from. Typically the repo root or a dedicated
# state directory.
AGENTS_CONSOLE_WORKSPACE=[ENTERPRISE: workspace root for agent state]

# Server bind
AGENTS_CONSOLE_HOST=0.0.0.0
AGENTS_CONSOLE_PORT=8091

# === Public-facing URL (for cross-service back-links) ===
AGENTS_CONSOLE_PUBLIC_URL=[ENTERPRISE: external URL for this console]

# === Sibling-service URLs ===
# The chat console (if deployed alongside).
CHAT_CONSOLE_URL=[ENTERPRISE: chat console URL]

# === Persistent state ===
# SQLite store for agent specs, runs, audit. Adopter-side path.
AGENTS_DB_PATH=[ENTERPRISE: agent state DB path]

# Audit log destination (append-only JSONL).
AGENTS_AUDIT_PATH=[ENTERPRISE: audit log path]

# === Cognitive engine substrate ===
# Required credentials per substrate adapter. Self-hosted substrate deployments
# may not need vendor API keys.
[ENTERPRISE: substrate adapter credentials — typically API keys or service
account credentials, one per cognitive engine variant in use]

# Self-hosted inference host configuration (Scenario 2; one or more entries)
OLLAMA_HOSTS=[ENTERPRISE: self-hosted inference endpoints, comma-separated]

# === Optional integrations ===
# Notification webhook, observability, etc.
[ENTERPRISE: notifier webhook URL, if console emits run-completion events]
[ENTERPRISE: observability endpoint, if console emits telemetry]
